# Start from a strict deny-all to avoid accidental huge contexts,
# then explicitly allow what the Dockerfile needs.
**

# Always include Docker build files
!Dockerfile
!.dockerignore

# Include repo-local translation assets
!translations/**
!scripts/**
!patches/**
!injected/**
!docker-entrypoint.sh

# Include CI-downloaded dist artifact (staged by .github/workflows/docker.yml)
!ci-dist
!ci-dist/**
